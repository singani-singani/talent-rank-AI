
Action: file_editor create /app/frontend/src/pages/NewJob.jsx --file-text "import { useState } from \"react\";
import { useNavigate } from \"react-router-dom\";
import { api } from \"@/lib/api\";
import { toast } from \"sonner\";
import { FloppyDisk, Sparkle } from \"@phosphor-icons/react\";

const SAMPLE = {
  title: \"Senior Full-Stack Engineer\",
  company: \"Nimbus Labs\",
  seniority: \"senior\",
  description:
    \"We are hiring a Senior Full-Stack Engineer to own product surfaces end-to-end. You will design APIs, build React interfaces, and ship production-quality code at speed. You will collaborate closely with design and product to launch features that customers love.\",
  required_skills: \"React, TypeScript, Node.js, PostgreSQL, AWS, System Design\",
};

export default function NewJob() {
  const nav = useNavigate();
  const [form, setForm] = useState({
    title: \"\",
    company: \"\",
    seniority: \"mid\",
    description: \"\",
    required_skills: \"\",
  });
  const [submitting, setSubmitting] = useState(false);

  const set = (k) => (e) => setForm({ ...form, [k]: e.target.value });

  const submit = async (e) => {
    e.preventDefault();
    if (!form.title.trim() || !form.description.trim()) {
      toast.error(\"Title and description are required\");
      return;
    }
    setSubmitting(true);
    try {
      const payload = {
        title: form.title.trim(),
        company: form.company.trim(),
        seniority: form.seniority,
        description: form.description.trim(),
        required_skills: form.required_skills
          .split(\",\")
          .map((s) => s.trim())
          .filter(Boolean),
      };
      const { data } = await api.post(\"/jobs\", payload);
      toast.success(\"Job created\");
      nav(`/jobs/${data.id}`);
    } catch (err) {
      toast.error(err?.response?.data?.detail || \"Could not create job\");
    } finally {
      setSubmitting(false);
    }
  };

  return (
    <div className=\"space-y-6\" data-testid=\"new-job-page\">
      <div className=\"flex items-end justify-between gap-4 border-b border-slate-200 pb-4\">
        <div>
          <div className=\"overline\">STEP 01</div>
          <h1 className=\"font-display text-4xl sm:text-5xl font-black tracking-tight\">Create a job</h1>
        </div>
        <button
          type=\"button\"
          data-testid=\"fill-sample-btn\"
          onClick={() => setForm({ ...form, ...SAMPLE })}
          className=\"btn-secondary text-sm h-9\"
        >
          <Sparkle size={14} /> Fill with sample
        </button>
      </div>

      <form onSubmit={submit} className=\"grid grid-cols-1 lg:grid-cols-3 gap-6\">
        <div className=\"lg:col-span-2 border border-slate-200 bg-white p-6 space-y-5\">
          <div>
            <label className=\"overline block mb-2\">Job title *</label>
            <input
              data-testid=\"job-title-input\"
              value={form.title}
              onChange={set(\"title\")}
              className=\"sharp-input\"
              placeholder=\"e.g. Senior Full-Stack Engineer\"
            />
          </div>
          <div className=\"grid grid-cols-1 sm:grid-cols-2 gap-5\">
            <div>
              <label className=\"overline block mb-2\">Company</label>
              <input
                data-testid=\"job-company-input\"
                value={form.company}
                onChange={set(\"company\")}
                className=\"sharp-input\"
                placeholder=\"Nimbus Labs\"
              />
            </div>
            <div>
              <label className=\"overline block mb-2\">Seniority</label>
              <select
                data-testid=\"job-seniority-select\"
                value={form.seniority}
                onChange={set(\"seniority\")}
                className=\"sharp-input\"
              >
                <option value=\"junior\">Junior</option>
                <option value=\"mid\">Mid</option>
                <option value=\"senior\">Senior</option>
                <option value=\"lead\">Lead / Principal</option>
              </select>
            </div>
          </div>
          <div>
            <label className=\"overline block mb-2\">Required skills (comma-separated)</label>
            <input
              data-testid=\"job-skills-input\"
              value={form.required_skills}
              onChange={set(\"required_skills\")}
              className=\"sharp-input\"
              placeholder=\"React, TypeScript, Node.js…\"
            />
          </div>
          <div>
            <label className=\"overline block mb-2\">Job description *</label>
            <textarea
              data-testid=\"job-description-textarea\"
              value={form.description}
              onChange={set(\"description\")}
              rows={12}
              className=\"sharp-textarea\"
              placeholder=\"Paste the full job description here — responsibilities, requirements, qualifications…\"
            />
          </div>
          <div className=\"flex items-center gap-3 pt-2\">
            <button type=\"submit\" data-testid=\"create-job-submit\" disabled={submitting} className=\"btn-primary\">
              <FloppyDisk size={16} weight=\"bold\" /> {submitting ? \"Creating…\" : \"Create job\"}
            </button>
            <button
              type=\"button\"
              onClick={() => nav(\"/jobs\")}
              data-testid=\"create-job-cancel\"
              className=\"btn-ghost text-sm\"
            >
              Cancel
            </button>
          </div>
        </div>

        <aside className=\"border border-slate-200 bg-white p-6 h-fit diag-bg\">
          <div className=\"overline mb-3\">GUIDANCE</div>
          <h3 className=\"font-display text-lg font-bold mb-3\">What makes a great JD?</h3>
          <ul className=\"space-y-3 text-sm text-slate-700 font-mono leading-relaxed\">
            <li className=\"border-l-2 border-[#002FA7] pl-3\">
              List concrete tech, tools, and outcomes — not marketing fluff.
            </li>
            <li className=\"border-l-2 border-slate-300 pl-3\">
              Mention seniority signals: scope, ownership, and mentorship.
            </li>
            <li className=\"border-l-2 border-slate-300 pl-3\">
              Add nice-to-haves separately — TalentRank uses them for culture fit.
            </li>
          </ul>
        </aside>
      </form>
    </div>
  );
}
"
