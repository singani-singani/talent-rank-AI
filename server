@api.post(\"/jobs\", response_model=Job)
async def create_job(payload: JobCreate):
    job = Job(
        id=str(uuid.uuid4()),
        title=payload.title.strip(),
        company=(payload.company or \"\").strip(),
        description=payload.description.strip(),
        required_skills=[s.strip() for s in payload.required_skills if s.strip()],
        seniority=payload.seniority or \"mid\",
        created_at=_now_iso(),
    )
    await db.jobs.insert_one(job.model_dump())
    return job


@api.get(\"/jobs\", response_model=List[Job])
async def list_jobs():
    docs = await db.jobs.find({}, {\"_id\": 0}).sort(\"created_at\", -1).to_list(500)
    return [_job_from_doc(d) for d in docs]


@api.get(\"/jobs/{job_id}\", response_model=Job)
async def get_job(job_id: str):
    doc = await db.jobs.find_one({\"id\": job_id}, {\"_id\": 0})
    if not doc:
        raise HTTPException(404, \"Job not found\")
