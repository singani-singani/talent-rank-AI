@api.get(\"/\")
async def root():
    return {\"service\": \"TalentRank AI\", \"status\": \"ok\"}


@api.get(\"/stats\")
async def stats():
    jobs_count = await db.jobs.count_documents({})
    cands_count = await db.candidates.count_documents({})
    ranked_count = await db.candidates.count_documents({\"ranked\": True})
    top_docs = (
        await db.candidates.find({\"ranked\": True}, {\"_id\": 0})
        .sort(\"scores.overall\", -1)
        .limit(3)
        .to_list(3)
    )
    return {
        \"jobs\": jobs_count,
        \"candidates\": cands_count,
        \"ranked\": ranked_count,
        \"avg_score\": (
            round(
                sum(c[\"scores\"][\"overall\"] for c in top_docs) / len(top_docs), 1
            )
            if top_docs
            else 0
        ),
        \"top\": top_docs,
    }


