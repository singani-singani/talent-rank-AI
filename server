@api.post(\"/jobs/{job_id}/rank\")
async def rank_all(job_id: str):
    job_doc = await db.jobs.find_one({\"id\": job_id}, {\"_id\": 0})
    if not job_doc:
        raise HTTPException(404, \"Job not found\")
    job = _job_from_doc(job_doc)

    cand_docs = await db.candidates.find({\"job_id\": job_id}, {\"_id\": 0}).to_list(500)
    if not cand_docs:
        raise HTTPException(400, \"No candidates to rank yet\")

    ranked, failed = 0, 0
    for d in cand_docs:
        cand = _candidate_from_doc(dict(d))
        try:
            result = await _rank_candidate_with_llm(job, cand)
            await db.candidates.update_one(
                {\"id\": cand.id},
                {
                    \"$set\": {
                        \"scores\": result[\"scores\"],
                        \"strengths\": result[\"strengths\"],
                        \"gaps\": result[\"gaps\"],
                        \"explanation\": result[\"explanation\"],
                        \"ranked\": True,
                    }
                },
            )
            ranked += 1
        except Exception as e:
            log.exception(f\"Ranking failed for {cand.name}: {e}\")
            failed += 1
    return {\"ranked\": ranked, \"failed\": failed, \"total\": len(cand_docs)}


@api.post(\"/candidates/{candidate_id}/rerank\", response_model=Candidate)
async def rerank_one(candidate_id: str):
    doc = await db.candidates.find_one({\"id\": candidate_id}, {\"_id\": 0})
    if not doc:
        raise HTTPException(404, \"Candidate not found\")
    cand = _candidate_from_doc(dict(doc))
    job_doc = await db.jobs.find_one({\"id\": cand.job_id}, {\"_id\": 0})
    if not job_doc:
        raise HTTPException(404, \"Job not found\")
    job = _job_from_doc(job_doc)
    result = await _rank_candidate_with_llm(job, cand)
    await db.candidates.update_one(
        {\"id\": cand.id},
        {
            \"$set\": {
                \"scores\": result[\"scores\"],
                \"strengths\": result[\"strengths\"],
                \"gaps\": result[\"gaps\"],
                \"explanation\": result[\"explanation\"],
                \"ranked\": True,
            }
        },
    )
    updated = await db.candidates.find_one({\"id\": cand.id}, {\"_id\": 0})
    return _candidate_from_doc(dict(updated))


