@api.post(\"/jobs/{job_id}/candidates/upload\", response_model=Candidate)
async def upload_candidate_resume(
    job_id: str,
    file: UploadFile = File(...),
    name: Optional[str] = Form(None),
):
    job_doc = await db.jobs.find_one({\"id\": job_id}, {\"_id\": 0})
    if not job_doc:
        raise HTTPException(404, \"Job not found\")

    data = await file.read()
    text = \"\"
    if file.filename and file.filename.lower().endswith(\".pdf\"):
        text = _extract_pdf_text(data)
    else:
        try:
            text = data.decode(\"utf-8\", errors=\"ignore\")
        except Exception:
            text = \"\"

    if not text.strip():
        raise HTTPException(400, \"Could not extract any text from the uploaded file\")

    heuristics = _quick_parse_resume(text)
    cand = Candidate(
        id=str(uuid.uuid4()),
        job_id=job_id,
        name=(name or heuristics[\"name\"] or (file.filename or \"Unknown\")).strip(),
        email=heuristics[\"email\"],
        years_experience=heuristics[\"years_experience\"],
        headline=\"\",
        education=\"\",
        skills=[],
        resume_text=text[:12000],
        created_at=_now_iso(),
    )
    await db.candidates.insert_one(cand.model_dump())
    return cand


