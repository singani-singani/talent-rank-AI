@api.get(\"/jobs/{job_id}/export.csv\")
async def export_csv(job_id: str):
    job_doc = await db.jobs.find_one({\"id\": job_id}, {\"_id\": 0})
    if not job_doc:
        raise HTTPException(404, \"Job not found\")
    docs = (
        await db.candidates.find({\"job_id\": job_id}, {\"_id\": 0})
        .sort([(\"ranked\", -1), (\"scores.overall\", -1)])
        .to_list(1000)
    )

    def gen():
        buf = io.StringIO()
        w = csv.writer(buf)
        w.writerow(
            [
                \"Rank\",
                \"Name\",
                \"Email\",
                \"Headline\",
                \"Overall\",
                \"Skills\",
                \"Experience\",
                \"Education\",
                \"CultureFit\",
                \"Explanation\",
            ]
        )
        yield buf.getvalue()
        buf.seek(0)
        buf.truncate(0)
        for i, d in enumerate(docs, 1):
            s = d.get(\"scores\", {})
            w.writerow(
                [
                    i,
                    d.get(\"name\", \"\"),
                    d.get(\"email\", \"\"),
                    d.get(\"headline\", \"\"),
                    s.get(\"overall\", 0),
                    s.get(\"skills\", 0),
                    s.get(\"experience\", 0),
                    s.get(\"education\", 0),
                    s.get(\"culture_fit\", 0),
                    (d.get(\"explanation\") or \"\").replace(\"\n\", \" \"),
                ]
            )
            yield buf.getvalue()
            buf.seek(0)
            buf.truncate(0)

    filename = f\"talentrank_{job_doc['title'].replace(' ', '_')}.csv\"
    return StreamingResponse(
        gen(),
        media_type=\"text/csv\",
        headers={\"Content-Disposition\": f'attachment; filename=\"{filename}\"'},
    )


