def _job_from_doc(d: dict) -> Job:
    d.pop(\"_id\", None)
    return Job(**d)


def _candidate_from_doc(d: dict) -> Candidate:
    d.pop(\"_id\", None)
    return Candidate(**d)


def _extract_pdf_text(data: bytes) -> str:
    try:
        reader = PdfReader(io.BytesIO(data))
        text_parts = []
        for page in reader.pages:
            text_parts.append(page.extract_text() or \"\")
        return \"\n\".join(text_parts).strip()
    except Exception as e:
        log.warning(f\"PDF parse failed: {e}\")
        return \"\"


NAME_RE = re.compile(r\"^([A-Z][a-z'\-]+(?:\s+[A-Z][a-z'\-]+){1,3})\", re.M)
EMAIL_RE = re.compile(r\"[\w\.-]+@[\w\.-]+\.\w+\")
YEARS_RE = re.compile(r\"(\d{1,2})\+?\s+years?\", re.I)


def _quick_parse_resume(text: str) -> dict:
    \"\"\"Very small heuristic parser used only for prefilling manual fields.\"\"\"
    name = \"\"
    email = \"\"
    years = 0.0
    m = EMAIL_RE.search(text)
    if m:
        email = m.group(0)
    m = NAME_RE.search(text.strip())
    if m:
        name = m.group(1).strip()
    m = YEARS_RE.search(text)
    if m:
        try:
            years = float(m.group(1))
        except ValueError:
            years = 0.0
    return {\"name\": name, \"email\": email, \"years_experience\": years}


def _extract_json(raw: str) -> dict:
    \"\"\"Extract the first JSON object from an LLM response.\"\"\"
    raw = raw.strip()
    if raw.startswith(\"```\"):
        raw = re.sub(r\"^```(?:json)?\", \"\", raw).strip()
        raw = re.sub(r\"```$\", \"\", raw).strip()
    start = raw.find(\"{\")
    end = raw.rfind(\"}\")
    if start != -1 and end != -1:
        raw = raw[start : end + 1]
    return json.loads(raw)


async def _rank_candidate_with_llm(job: Job, cand: Candidate) -> dict:
    \"\"\"Call Claude Sonnet 4.5 to score & explain a single candidate.\"\"\"
    session_id = f\"rank-{job.id}-{cand.id}\"
    system = (
        \"You are TalentRank AI, a rigorous, explainable recruiting analyst. \"
        \"You evaluate ONE candidate against ONE job description and return a strict JSON object. \"
        \"Be objective, evidence-based, and concise. Never invent facts not present in the input. \"
        \"Return ONLY valid JSON, no prose, no markdown fences.\"
    )
    chat = LlmChat(api_key=EMERGENT_LLM_KEY, session_id=session_id, system_message=system).with_model(
        \"anthropic\", \"claude-sonnet-4-5-20250929\"
    )

    prompt = f\"\"\"
Evaluate the candidate below against the job. Output STRICT JSON with this exact shape:

{{
  \"scores\": {{
    \"skills\": <int 0-100>,
    \"experience\": <int 0-100>,
    \"education\": <int 0-100>,
    \"culture_fit\": <int 0-100>,
    \"overall\": <int 0-100>
  }},
  \"strengths\": [\"short bullet\", \"short bullet\", \"short bullet\"],
  \"gaps\": [\"short bullet\", \"short bullet\"],
  \"explanation\": \"2-3 sentence rationale tying evidence in the resume to the job requirements.\"
}}

Rules:
- \"overall\" MUST be a weighted average: 0.45*skills + 0.30*experience + 0.10*education + 0.15*culture_fit, rounded.
- If information is missing, penalise that dimension (e.g. no education info => education ~40).
- Culture-fit = seniority alignment + industry/domain alignment + soft-skills signals.
- Return ONLY the JSON object.

=== JOB ===
Title: {job.title}
Company: {job.company}
Seniority target: {job.seniority}
Required skills: {\", \".join(job.required_skills) or \"(inferred from description)\"}
Description:
{job.description}

=== CANDIDATE ===
Name: {cand.name}
Headline: {cand.headline}
Years of experience: {cand.years_experience}
Education: {cand.education}
Skills: {\", \".join(cand.skills) or \"(inferred from resume)\"}
Resume / bio:
{cand.resume_text or \"(no resume text supplied)\"}
\"\"\".strip()

    reply = await chat.send_message(UserMessage(text=prompt))
    log.info(f\"LLM reply for {cand.name} (len={len(reply)})\")
    parsed = _extract_json(reply)

    scores = parsed.get(\"scores\", {})
    return {
        \"scores\": {
            \"skills\": int(scores.get(\"skills\", 0)),
            \"experience\": int(scores.get(\"experience\", 0)),
            \"education\": int(scores.get(\"education\", 0)),
            \"culture_fit\": int(scores.get(\"culture_fit\", 0)),
            \"overall\": int(scores.get(\"overall\", 0)),
        },
        \"strengths\": [str(x) for x in parsed.get(\"strengths\", [])][:5],
        \"gaps\": [str(x) for x in parsed.get(\"gaps\", [])][:5],
        \"explanation\": str(parsed.get(\"explanation\", \"\")).strip(),
    }


