const Stat = ({ label, value, icon: Icon, testid }) => (
  <div className=\"grid-cell p-5\" data-testid={testid}>
    <div className=\"flex items-start justify-between\">
      <div className=\"overline\">{label}</div>
      <Icon size={18} weight=\"duotone\" className=\"text-[#002FA7]\" />
    </div>
    <div className=\"font-display text-4xl font-black mt-3 tracking-tight\">{value}</div>
  </div>
);

