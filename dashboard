            </div>
            <Trophy size={20} className=\"text-[#002FA7]\" weight=\"fill\" />
          </div>
          {stats.top.length === 0 ? (
            <div className=\"p-8 text-center text-sm text-slate-500 font-mono\">
              No ranked candidates yet — create a job to get started.
            </div>
          ) : (
            <ul className=\"divide-y divide-slate-200\">
              {stats.top.map((c, i) => {
                const col = scoreColor(c.scores?.overall ?? 0);
                return (
                  <li key={c.id} className=\"px-5 py-3 flex items-center gap-4 hover:bg-slate-50\" data-testid={`top-cand-${i}`}>
                    <span className=\"font-mono text-xs w-6 text-slate-400\">#{i + 1}</span>
                    <div className=\"flex-1 min-w-0\">
                      <div className=\"font-medium truncate\">{c.name}</div>
                      <div className=\"text-xs text-slate-500 font-mono truncate\">{c.headline || c.email || \"—\"}</div>
                    </div>
                    <span className={`score-pill ${col.bg} ${col.text} ${col.border}`}>{c.scores?.overall ?? 0}</span>
                  </li>
                );
              })}
            </ul>
          )}
        </div>

        <div className=\"border border-slate-200 bg-white\">
          <div className=\"flex items-center justify-between px-5 py-3 border-b border-slate-200\">
            <div>
              <div className=\"overline\">RECENT JOBS</div>
              <h3 className=\"font-display text-lg font-bold\">Postings</h3>
            </div>
            <Link to=\"/jobs\" data-testid=\"dash-view-all-jobs\" className=\"text-xs font-mono text-[#002FA7] hover:underline\">
              view all →
            </Link>
          </div>
          {jobs.length === 0 ? (
            <div className=\"p-6 text-center text-sm text-slate-500 font-mono\">
              <Briefcase size={28} className=\"mx-auto mb-2 text-slate-300\" />
              No jobs yet.
              <div className=\"mt-4\">
                <Link to=\"/jobs/new\" data-testid=\"dash-empty-create-job\" className=\"btn-primary text-sm h-9\">
                  + Create your first job
                </Link>
              </div>
            </div>
          ) : (
            <ul className=\"divide-y divide-slate-200\">
              {jobs.map((j) => (
                <li key={j.id}>
                  <Link
                    to={`/jobs/${j.id}`}
                    data-testid={`dash-job-${j.id}`}
                    className=\"block px-5 py-3 hover:bg-slate-50 transition-colors\"
                  >
                    <div className=\"flex items-center justify-between gap-2\">
                      <span className=\"font-medium truncate\">{j.title}</span>
                      <ArrowRight size={14} className=\"text-slate-400\" />
                    </div>
                    <div className=\"text-xs text-slate-500 font-mono\">{j.company || \"—\"} · {j.seniority}</div>
                  </Link>
                </li>
              ))}
            </ul>
          )}
        </div>
      </section>
    </div>
  );
}
