  const [stats, setStats] = useState({ jobs: 0, candidates: 0, ranked: 0, avg_score: 0, top: [] });
  const [jobs, setJobs] = useState([]);
  const [loading, setLoading] = useState(true);

  const load = async () => {
    try {
      const [s, j] = await Promise.all([api.get(\"/stats\"), api.get(\"/jobs\")]);
      setStats(s.data);
      setJobs(j.data.slice(0, 4));
    } catch (e) {
      toast.error(\"Could not load dashboard\");
    } finally {
      setLoading(false);
    }
  };

  useEffect(() => {
    load();
  }, []);

  return (
