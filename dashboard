      {/* Hero */}
      <section className=\"border border-slate-200 bg-white diag-bg grain relative overflow-hidden\">
        <div className=\"p-8 sm:p-12 grid grid-cols-1 md:grid-cols-12 gap-8 items-end\">
          <div className=\"md:col-span-8\">
