          <Stat label=\"Ranked\" value={loading ? \"—\" : stats.ranked} icon={ChartLineUp} testid=\"stat-ranked\" />
          <Stat label=\"Avg. top score\" value={loading ? \"—\" : stats.avg_score} icon={Trophy} testid=\"stat-avg\" />
        </div>
      </section>

